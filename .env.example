# Copy to .env.local for local Docker Compose dev (MySQL runs in the `db` service).
# Copy to .env.prod and fill in real values for the Aruba deploy target.
# Never commit .env.local or .env.prod.

DB_HOST=db
DB_NAME=sse_chat
DB_USER=app
DB_PASS=app_password

# local | prod — when prod, session cookie is emitted with Secure flag (requires HTTPS)
APP_ENV=local

# Bcrypt hash of the admin panel password. Generate with:
#   php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT), PHP_EOL;"
# Leave empty to disable admin login (all password attempts reject).
# NOTE: every `$` in the hash must be written as `$$` — compose re-expands
# $-sequences during env interpolation, and an un-escaped hash will get mangled.
# The default below verifies the password "admin_test_pw" — only suitable for
# local dev / CI. Replace with a real hash in production.
ADMIN_PASSWORD_HASH=$$2y$$10$$a9x/496QpqGHqkJOwf4gZOazi6fVaUlFQ5RAAUNEFB.IWVXkYN1oS
