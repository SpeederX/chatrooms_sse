# Copy to .env.local for local Docker Compose dev (MySQL runs in the `db` service).
# Copy to .env.prod and fill in real values for the Aruba deploy target.
# Never commit .env.local or .env.prod.

DB_HOST=db
DB_NAME=sse_chat
DB_USER=app
DB_PASS=app_password

# local | prod — when prod, session cookie is emitted with Secure flag (requires HTTPS)
APP_ENV=local
